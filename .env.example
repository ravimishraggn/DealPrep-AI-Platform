# Copy to .env and adjust. All vars are prefixed DEALPREP_.

# Postgres (docker-compose default)
DEALPREP_DATABASE_URL=postgresql+psycopg://dealprep:dealprep@localhost:5432/dealprep

# Neo4j (docker-compose default)
DEALPREP_NEO4J_URI=bolt://localhost:7687
DEALPREP_NEO4J_USER=neo4j
DEALPREP_NEO4J_PASSWORD=dealprep-graph

# Optional: enable real Claude relationship extraction (else rule-based fallback)
# DEALPREP_ANTHROPIC_API_KEY=sk-ant-...

# Dev demo scheduler (clamps poll intervals so runs fire quickly)
DEALPREP_DEV_MODE=true
DEALPREP_DEV_MIN_INTERVAL_SECONDS=10
